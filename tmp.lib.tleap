###########################################
source leaprc.protein.ff19SB
source leaprc.DNA.OL15
source leaprc.gaff
###########################################
addpath ./dat
loadamberparams frcmod.modxna
###########################################
JCW = loadmol2 tmp.opt.mol2
set JCW restype nucleic
set JCW name JCW
set JCW head JCW.1.P
set JCW tail JCW.1.O3'
saveoff JCW JCW.lib
quit
